"""Type stubs for the Rust extension module ``scdata._scdata``.

These mirror the pyclasses registered by ``rust/scdata/src/pybind.rs``.  The
simple config dataclasses (``_DataBankConfig``, ``_IoConfig``, ...) are exposed
verbatim; ``_DataBank`` and ``_PrefetchCells`` are private and wrapped by
:mod:`scdata.databank` into the public ``ScDataBank`` / prefetch iterator.
"""

from __future__ import annotations

from typing import Any, Iterable

from numpy.typing import NDArray

import numpy as np

from scdata.data._dataset import DenseDataset, DType, SparseDataset

__version__: str

def kernel_name() -> str: ...
def kernel_version() -> str: ...
def _zip_stored_offsets(path: str, header_offsets: list[int]) -> list[int]: ...
def _decode_index_payload(
    payload: bytes,
    offsets: NDArray[np.uint64],
    lengths: NDArray[np.uint64],
    dtype: DType,
    codec: Any,
    count: int,
) -> NDArray[np.uint64]: ...
def _decode_index_chunks(
    chunks: Iterable[bytes],
    dtype: DType,
    codec: Any,
    count: int,
) -> NDArray[np.uint64]: ...

class DataBankError(RuntimeError):
    """Raised when a Rust-side DataBank operation fails."""

# ---------------------------------------------------------------------------
# _DatasetId — simple value object, exposed directly
# ---------------------------------------------------------------------------

class _DatasetId:
    """Opaque ``(slot, generation)`` handle returned by ``register_*``."""

    def __init__(self, slot: int, generation: int) -> None: ...
    @property
    def slot(self) -> int: ...
    @property
    def generation(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __repr__(self) -> str: ...

# ---------------------------------------------------------------------------
# _MissingGenePolicy — simple enum, exposed directly
# ---------------------------------------------------------------------------

class _MissingGenePolicy:
    """Policy for gene names absent from the dataset (``ZERO`` / ``ERROR``)."""

    ZERO: _MissingGenePolicy
    ERROR: _MissingGenePolicy
    def __init__(self, policy: str) -> None: ...
    def __repr__(self) -> str: ...

