# ---------------------------------------------------------------------------
# _DataBank — private, wrapped by scdata.databank.ScDataBank
# ---------------------------------------------------------------------------

class _DataBank:
    def __init__(self, config: _DataBankConfig | None = None) -> None: ...
    def register_dense(self, ds: DenseDataset, store_path: str) -> _DatasetId: ...
    def register_sparse_csr(self, ds: SparseDataset, store_path: str) -> _DatasetId: ...
    def unregister(self, id: _DatasetId) -> None: ...
    def dataset_genes(self, id: _DatasetId) -> list[str]: ...
    def dataset_num_cells(self, id: _DatasetId) -> int: ...
    def dataset_num_genes(self, id: _DatasetId) -> int: ...
    def dataset_dtype(self, id: _DatasetId) -> DType: ...
    def access_cells(
        self,
        id: _DatasetId,
        cells: list[int],
        dtype: DType | None = None,
    ) -> NDArray[np.generic]: ...
    def access_cells_array(
        self,
        id: _DatasetId,
        cells: NDArray[np.intp],
        dtype: DType | None = None,
    ) -> NDArray[np.generic]: ...
    def access_cells_by_gene_names(
        self,
        id: _DatasetId,
        cells: list[int],
        gene_names: list[str],
        missing: _MissingGenePolicy | None = None,
        dtype: DType | None = None,
    ) -> NDArray[np.generic]: ...
    def access_cells_by_gene_names_array(
        self,
        id: _DatasetId,
        cells: NDArray[np.intp],
        gene_names: list[str],
        missing: _MissingGenePolicy | None = None,
        dtype: DType | None = None,
    ) -> NDArray[np.generic]: ...
    def prefetch_cells(
        self,
        id: _DatasetId,
        batches: Iterable[list[int]],
        config: _ScheduledPrefetchConfig | None = None,
    ) -> _PrefetchCells: ...
    def prefetch_cells_arrays(
        self,
        id: _DatasetId,
        batches: Iterable[NDArray[np.intp]],
        config: _ScheduledPrefetchConfig | None = None,
    ) -> _PrefetchCells: ...
    def prefetch_cells_by_gene_names(
        self,
        id: _DatasetId,
        batches: Iterable[list[int]],
        gene_names: list[str],
        missing: _MissingGenePolicy | None = None,
        config: _ScheduledPrefetchConfig | None = None,
    ) -> _PrefetchCells: ...
    def prefetch_cells_by_gene_names_arrays(
        self,
        id: _DatasetId,
        batches: Iterable[NDArray[np.intp]],
        gene_names: list[str],
        missing: _MissingGenePolicy | None = None,
        config: _ScheduledPrefetchConfig | None = None,
    ) -> _PrefetchCells: ...
    def __repr__(self) -> str: ...

